# ===============================
# K-LMS Automation Environment Template
# Copy this file to `.env` and fill values.
# NEVER commit your actual .env file to GitHub.
# ===============================

# --- Keio University (K-LMS) Login ---
KEIO_USER=your_keio_email@keio.jp
KEIO_PASS=your_keio_password

# --- Google Account for OAuth / Drive Upload ---
GOOGLE_EMAIL=your_google_email@gmail.com
GOOGLE_PASSWORD=your_google_password
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id_here

# --- Gemini API (Google Generative AI) ---
GEMINI_API_KEY=your_gemini_api_key_here
